{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "references": [
    { "path": "packages/schema" },
    { "path": "packages/extractor-core" },
    { "path": "packages/extractor-linkedin" },
    { "path": "packages/ui-overlay" },
    { "path": "packages/transport-download" },
    { "path": "packages/transport-clipboard" },
    { "path": "packages/transport-webhook" },
    { "path": "apps/bookmarklet" }
  ],
  "files": []
}
