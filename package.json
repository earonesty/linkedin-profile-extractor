{
  "name": "linkedin-profile-extractor",
  "version": "0.1.0",
  "private": true,
  "description": "Client-side LinkedIn profile data extractor \u2014 reusable library and bookmarklet app",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "tsc --build",
    "lint": "eslint 'packages/*/src/**/*.ts' 'apps/*/src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fixtures": "vitest run tests/parser/",
    "clean": "rm -rf packages/*/dist apps/*/dist",
    "dev": "LIEX_RUNTIME_URL=http://localhost:3333/runtime.js node scripts/build-bookmarklet.mjs && node scripts/serve-bookmarklet.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.41.0",
    "@playwright/test": "^1.41.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@esbuild/*"
    ]
  }
}